# Copy to /etc/asv-dashboard.env and protect with chmod 600.
ASV_ID=default
ASV_BACKEND_HOST=0.0.0.0
ASV_BACKEND_PORT=8080
# Browser-compatible raw surface camera URL (20–30 FPS), if the camera
# source is hosted separately from this bridge. Leave empty until verified.
ASV_STREAM_URL=
# Comma-separated browser origins allowed to read direct live API responses.
ASV_CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000
# The bridge fallback/debug endpoint is /stream.mjpg; it is not the main feed.
ASV_FALLBACK_MAX_BASE64=180000
ASV_FALLBACK_MAX_FPS=1
ASV_FRAME_WAIT_TIMEOUT=1

# Read-only Pixhawk telemetry. No arm, mode change, navigation, or RC command.
ASV_PIXHAWK_ENABLED=false
ASV_PIXHAWK_ENDPOINT=/dev/ttyACM0
ASV_PIXHAWK_BAUD=115200
ASV_PIXHAWK_UPDATE_HZ=1
ASV_PIXHAWK_HEARTBEAT_TIMEOUT=3
ASV_PIXHAWK_TRACK_MAX_POINTS=500
ASV_PIXHAWK_RECONNECT_SECONDS=3

# Supabase is optional rollback publishing; leave both empty for direct live mode.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
