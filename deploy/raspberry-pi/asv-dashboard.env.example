# Copy to /etc/asv-dashboard.env and protect with chmod 600.
ASV_ID=default
ASV_BACKEND_HOST=0.0.0.0
ASV_BACKEND_PORT=8080
# Public HTTPS tunnel URL consumed by the Vercel dashboard.
ASV_STREAM_URL=https://camera.example.com/stream.mjpg
ASV_FALLBACK_MAX_BASE64=180000
ASV_FALLBACK_MAX_FPS=1
ASV_FRAME_WAIT_TIMEOUT=1

# Service-role key stays on the Raspberry Pi. Never expose it to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
